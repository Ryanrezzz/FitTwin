# ──────────────────────────────────────────────────────────────
# FitTwin — environment template. Copy to .env and fill in.
# ──────────────────────────────────────────────────────────────

# App
APP_ENV=dev                      # dev | prod
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # comma-separated allow-list
AGENT_RECURSION_LIMIT=25         # safety cap on the LangGraph loop

# Database (MongoDB)
DB_ENABLED=true                  # false → run API offline (agent core only; auth/profile 503)
MONGO_URI=mongodb://mongo:27017
MONGO_DB=fittwin
MONGO_TIMEOUT_MS=2000            # fail fast if Mongo is unreachable

# Cache / rate-limit (optional in V1)
REDIS_URI=redis://redis:6379/0

# Security
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# LLM provider — pick one: gemini | openai | ollama | fake
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fittwin-dev
SENTRY_DSN=

# Frontend (Vite) — prefix VITE_ to expose to the browser
VITE_API_BASE_URL=http://localhost:8000
